<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RouteMate Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body data-user-id="<%= user.id %>">
    <!-- ★★★ ADD HIDDEN INPUT AS BACKUP ★★★ -->
    <input type="hidden" id="current-user-id" value="<%= user.id %>">
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">
                <i class="bi bi-geo-alt-fill me-2"></i>RouteMate
            </a>
            <div class="navbar-nav ms-auto">
                <span class="navbar-text me-3">
                    Welcome, <strong><%= user.name %></strong>! (<%= user.role %>)
                </span>
                <% if (user.role === 'rider') { %>
                    <a href="/my-bookings" class="btn btn-outline-light btn-sm me-2">
                       <i class="bi bi-journal-check me-1"></i>My Bookings
                    </a>
                <% } else if (user.role === 'driver') { %>
                    <a href="/my-rides" class="btn btn-outline-light btn-sm me-2">
                        <i class="bi bi-car-front me-1"></i>My Rides
                    </a>
                <% } %>
                <a href="/profile" class="btn btn-outline-light btn-sm me-2">
                    <i class="bi bi-person me-1"></i>Profile
                </a>
                <a href="/auth/logout" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </a>
            </div>
        </div>
    </nav>

    <!-- Success/Error Messages -->
<% if (typeof success !== 'undefined' && success) { %>
    <div class="container mt-3">
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
<% } %>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="container mt-3">
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle"></i> <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
<% } %>

    <!-- Dashboard Header -->
    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <h2>Your Dashboard</h2>
                <p class="text-muted">Manage your rides and bookings here.</p>
            </div>
        </div>
    </div>

    <!-- Driver-Specific Content -->
    <% if (user.role === 'driver') { %>
        <div class="container mt-4">
            <!-- Button to trigger Create Ride Modal -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4>Your Offered Rides</h4>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createRideModal">
                    <i class="bi bi-plus-circle me-1"></i>Offer a New Ride
                </button>
            </div>

            <!-- Driver's Rides List -->
            <% if (rides.length > 0) { %>
                <div class="row">
                    <% rides.forEach(function(ride) { %>
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title"><%= ride.start_location %> to <%= ride.end_location %></h5>


                                    

                                    <!-- ADD DRIVER RATING HERE -->
                                    <% if (ride.avg_rating > 0) { %>
                                                            <div class="mb-2">
                                            <i class="bi bi-star-fill text-warning"></i> 
                                           <strong>Driver Rating:</strong> 
                                           <span class="badge rating-badge">
                                                <%= ride.avg_rating %>/5
                                            </span>
                                        </div>
                                    <% } %>

                                    <p class="card-text">
                                        <i class="bi bi-clock"></i> <strong>Time:</strong> 
                                        <%= new Date(ride.ride_time).toLocaleString() %>
                                    </p>
                                    <p class="card-text">
                                        <i class="bi bi-people"></i> <strong>Seats Available:</strong> 
                                        <span class="badge bg-<%= ride.seats_available > 0 ? 'success' : 'danger' %> seats-badge">
                                            <%= ride.seats_available %>
                                        </span>
                                    </p>

                                    <!-- NEW: Delete Button -->
                                <div class="d-grid gap-2">
                                    <button class="btn btn-outline-primary btn-sm" 
                                            onclick="openRideChat('<%= ride.id %>', '<%= ride.driver_id %>', 'Riders')">
                                        <i class="bi bi-chat"></i> Chat with Riders
                                    </button>
                                    <!-- ★★★ FIXED TRACKING BUTTON ★★★ -->
                                    <button class="btn btn-success btn-sm start-tracking-btn" 
                                            data-ride-id="<%= ride.id %>"
                                            onclick="driverTracking.startTracking('<%= ride.id %>')">
                                        <i class="bi bi-geo-alt"></i> Start Sharing Location
                                    </button>                           

                                    <button class="btn btn-danger btn-sm delete-ride-btn" 
                                            data-ride-id="<%= ride.id %>"
                                            data-ride-route="<%= ride.start_location %> to <%= ride.end_location %>">
                                        <i class="bi bi-trash"></i> Delete Ride
                                    </button>
                                </div>


                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> You haven't offered any rides yet. Click the button above to get started!
                </div>
            <% } %>
        </div>
    <% } %>

    <!-- Rider-Specific Content -->
    <% if (user.role === 'rider') { %>
        <div class="container mt-4">
            <h4>Available Rides</h4>
            <p class="text-muted">Find and book a ride that matches your route.</p>

<!-- Search and Filter Section -->
<% if (user.role === 'rider') { %>
<div class="card mb-4">
    <div class="card-header bg-light">
        <h5 class="card-title mb-0"><i class="bi bi-search me-2"></i>Search & Filter Rides</h5>
    </div>
    <div class="card-body">
        <form method="GET" action="/dashboard">
            <div class="row g-3">
                <div class="col-md-4">
                    <label for="search" class="form-label">Quick Search</label>
                    <input type="text" class="form-control" id="search" name="search" 
                           placeholder="Driver name, location..." 
                           value="<%= typeof filters !== 'undefined' ? filters.search : '' %>">
                </div>
                <div class="col-md-3">
                    <label for="start_location" class="form-label">From</label>
                    <input type="text" class="form-control" id="start_location" name="start_location" 
                           placeholder="Start location" 
                           value="<%= typeof filters !== 'undefined' ? filters.start_location : '' %>">
                </div>
                <div class="col-md-3">
                    <label for="end_location" class="form-label">To</label>
                    <input type="text" class="form-control" id="end_location" name="end_location" 
                           placeholder="Destination" 
                           value="<%= typeof filters !== 'undefined' ? filters.end_location : '' %>">
                </div>
                <div class="col-md-2">
                    <label for="date" class="form-label">Date</label>
                    <input type="date" class="form-control" id="date" name="date" 
                           value="<%= typeof filters !== 'undefined' ? filters.date : '' %>">
                </div>
            </div>
            <div class="row mt-3">
                <div class="col-12">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="bi bi-funnel"></i> Apply Filters
                    </button>
                    <a href="/dashboard" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Clear
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Results Count -->
<% if (typeof filters !== 'undefined' && (filters.search || filters.start_location || filters.end_location || filters.date)) { %>
    <div class="alert alert-info mb-4">
        <i class="bi bi-info-circle"></i> 
        Found <strong><%= rides.length %></strong> ride(s) matching your criteria
        <a href="/dashboard" class="alert-link">Show all rides</a>
    </div>
<% } %>
<% } %>

            <!-- Rider's Available Rides List -->
            <% if (user.role === 'rider') { %>
    <% if (rides.length > 0) { %>
        <div class="row">
            <% rides.forEach(function(ride) { %>
                <div class="col-md-6 col-lg-4 mb-4">
    <div class="card h-100 shadow-sm" 
         data-ride-id="<%= ride.id %>"
         data-distance="<%= ride.distance_km || 25 %>"
         data-duration="<%= ride.duration_min || 40 %>"
         data-traffic="<%= ride.traffic_level || 2 %>"
         data-seats="<%= ride.seats_available %>">
        
        <div class="card-body">
            <h5 class="card-title"><%= ride.start_location %> to <%= ride.end_location %></h5>

        <!-- ★★★ AI PREDICTED FARE DISPLAY ★★★ -->
            <div class="ai-fare-prediction mb-3 loading">
                <div class="alert alert-info py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <i class="bi bi-robot"></i> 
                            <strong>AI Predicted Fare:</strong> 
                            <span id="predicted-fare-<%= ride.id %>">Calculating...</span>
                        </div>
                        <small class="text-muted">85% confidence</small>
                    </div>
                </div>
            </div>   
                            
                            <!-- ★★★ ADD RATING DISPLAY RIGHT HERE ★★★ -->
                             
                            <!-- ADD CHAT BUTTON FOR BOOKED RIDES -->
                            <% if (ride.user_has_booking) { %>
                                <div class="d-grid gap-2 mt-3">
                                    <button class="btn btn-outline-primary btn-sm" 
                                            onclick="openRideChat('<%= ride.id %>', '<%= ride.driver_id %>', '<%= ride.driver_name %>')">
                                        <i class="bi bi-chat"></i> Chat with Driver
                                    </button>
                                    <!-- ★★★ ADD TRACK RIDE BUTTON ★★★ -->
                                    <button class="btn btn-info btn-sm track-ride-btn" 
                                            data-ride-id="<%= ride.id %>"
                                            data-driver-name="<%= ride.driver_name %>">
                                        <i class="bi bi-map"></i> Track Driver
                                    </button>
                                </div>
                            <% } %>


                            <!-- ★★★ ADD THIS DESCRIPTION CODE HERE ★★★ -->
                            <!--  if (ride.description && ride.description.length > 0) { %>
                              <div class="alert alert-light border mb-2 p-2" style="font-style: italic; background-color: #f8f9fa;">
                                <i class="bi bi-stars text-primary me-1"></i>
                                " ride.description %>"
                              </div>
                            } %> -->
                            <!-- ★★★ END DESCRIPTION CODE ★★★ -->


                <% if (ride.avg_rating && parseFloat(ride.avg_rating) > 0) { %>
    <!-- Show rating -->
    <div class="mb-2">
        <div class="d-flex align-items-center">
            <div class="rating-stars me-2">
                <% for (let i = 1; i <= 5; i++) { %>
                    <i class="bi bi-star-fill <%= i <= Math.round(ride.avg_rating) ? 'text-warning' : 'text-secondary' %>"></i>
                <% } %>
            </div>
            <strong class="me-2">
                <% if (ride.avg_rating) { %>
                    <%= parseFloat(ride.avg_rating).toFixed(1) %>
                 <% } else { %>
                    0.0
                <% } %>
            </strong>
            <span class="text-muted">(<%= ride.total_ratings %> reviews)</span>
        </div>
        
        <div class="mt-1">
            <a href="/ratings/<%= ride.driver_id %>" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-chat-left-text"></i> Read Reviews
            </a>
        </div>
    </div>
<% } else { %>
    <div class="mb-2">
        <span class="badge bg-secondary">New driver - no ratings yet</span>
    </div>
<% } %>
                <!-- ★★★ END RATING DISPLAY ★★★ -->



                            <!-- NEW: Show Pickup Instructions -->
                            <% if (ride.pickup_instructions) { %>
                                <div class="alert alert-info py-2 mb-3">
                                    <small>
                                        <i class="bi bi-info-circle"></i> 
                                        <strong>Pickup:</strong> <%= ride.pickup_instructions %>
                                    </small>
                                </div>
                            <% } %>
                            
                            <p class="card-text">
                                <i class="bi bi-person"></i> <strong>Driver:</strong> <%= ride.driver_name %>
                            </p>
                            <p class="card-text">
                                <i class="bi bi-clock"></i> <strong>Time:</strong> 
                                <%= new Date(ride.ride_time).toLocaleString() %>
                            </p>
                            <p class="card-text">
                                <i class="bi bi-people"></i> <strong>Seats Left:</strong> 
                                <span class="badge bg-<%= ride.seats_available > 0 ? 'success' : 'danger' %> seats-badge">
                                    <%= ride.seats_available %>
                                </span>
                            </p>
                            <div class="d-grid gap-2">
                                <% if (ride.seats_available > 0) { %>
                                    <% if (!ride.user_has_booking) { %>
                                    <button class="btn btn-primary btn-sm book-ride-btn" 
                                            data-ride-id="<%= ride.id %>" 
                                            data-seats-available="<%= ride.seats_available %>">
                                        Book This Ride
                                    </button>
                                    <% } else { %>
                                        <!-- Already Booked Message -->
                                        <button class="btn btn-success btn-sm" disabled>
                                        <i class="bi bi-check-circle"></i> Booked
                                        </button>
                                    <% } %>
                                <% } else { %>
                                    <button class="btn btn-secondary btn-sm" disabled>Fully Booked</button>
                                <% } %>
                                <!-- NEW: Quick Cancel Button (if rider has booked this ride) -->
                                <% if (ride.user_has_booking && ride.user_booking_status === 'confirmed') { %>
                                <% const isFutureRide = new Date(ride.ride_time) > new Date(); %>
                                <% if (isFutureRide) { %>
                                    <button class="btn btn-outline-danger btn-sm cancel-booking-btn" 
                                        data-booking-id="<%= ride.user_booking_id %>"
                                        data-ride-route="<%= ride.start_location %> to <%= ride.end_location %>">
                                    <i class="bi bi-x-circle"></i> Cancel Booking
                                    </button>
                                <% } else { %>
                                    <button class="btn btn-outline-secondary btn-sm" disabled>
                                        <i class="bi bi-clock-history"></i> Ride Completed
                                        </button>
                                    <% } %>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No rides are currently available. Please check back later.
        </div>
    <% } %>
<% } %>
        </div>
    <% } %>

    <!-- Create Ride Modal (for Drivers) -->
    <% if (user.role === 'driver') { %>
    <div class="modal fade" id="createRideModal" tabindex="-1" aria-labelledby="createRideModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="createRideModalLabel">Offer a New Ride</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/api/rides" method="POST" onsubmit="return confirm('Create this ride?')">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="startLocation" class="form-label">Start Location</label>
                            <input type="text" class="form-control" id="startLocation" name="start_location" required>
                        </div>
                        <div class="mb-3">
                            <label for="endLocation" class="form-label">Destination</label>
                            <input type="text" class="form-control" id="endLocation" name="end_location" required>
                        </div>


                        
                        <!-- ★★★ NEW FIELDS FOR AI PREDICTION ★★★ -->
    <div class="row">
        <div class="col-md-6 mb-3">
            <label for="distanceKm" class="form-label">
                <i class="bi bi-signpost"></i> Distance (km)
            </label>
            <input type="number" class="form-control" id="distanceKm" name="distance_km" 
                   step="0.1" min="1" required placeholder="e.g., 25.5">
        </div>
        <div class="col-md-6 mb-3">
            <label for="durationMin" class="form-label">
                <i class="bi bi-clock"></i> Duration (minutes)
            </label>
            <input type="number" class="form-control" id="durationMin" name="duration_min" 
                   min="5" required placeholder="e.g., 45">
        </div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label for="trafficLevel" class="form-label">
                <i class="bi bi-traffic-cone"></i> Traffic Level
            </label>
            <select class="form-control" id="trafficLevel" name="traffic_level" required>
                <option value="1">🚦 Low Traffic</option>
                <option value="2" selected>🚦 Medium Traffic</option>
                <option value="3">🚦 High Traffic</option>
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label for="seatsAvailable" class="form-label">
                <i class="bi bi-people"></i> Seats Available
            </label>
            <input type="number" class="form-control" id="seatsAvailable" name="seats_available" 
                   min="1" value="3" required>
        </div>
    </div>

    <!-- Rest of your existing fields -->







                        
                    <div class="mb-3">
                        <label for="pickupInstructions" class="form-label">
                            <i class="bi bi-geo-alt"></i> Pickup Instructions
                        </label>
                        <textarea class="form-control" id="pickupInstructions" name="pickup_instructions" 
                                rows="2" placeholder="Example: 'Wait near the main gate', 'Call when you arrive', 'Look for red building'"
                                maxlength="200"></textarea>
                        <div class="form-text">Help drivers find you easily. These instructions will be visible to riders when they book.</div>
                    </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="rideTime" class="form-label">Date & Time</label>
                                <input type="datetime-local" class="form-control" id="rideTime" name="ride_time" required>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create Ride</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <% } %>

    

    <!-- Bootstrap & JavaScript -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Rating Modal -->
    <div class="modal fade" id="ratingModal" tabindex="-1" aria-labelledby="ratingModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="ratingModalLabel">Rate Your Ride</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="ratingForm">
                    <div class="modal-body">
                        <input type="hidden" id="ratingRideId" name="ride_id">
                        
                        <div class="mb-3">
                            <label class="form-label">How was your ride?</label>
                            <div class="rating-stars mb-3">
                                <% for (let i = 1; i <= 5; i++) { %>
                                    <i class="bi bi-star rating-star" data-rating="<%= i %>" style="cursor: pointer; font-size: 2rem; color: #ddd;"></i>
                                <% } %>
                            </div>
                            <input type="hidden" id="ratingValue" name="rating" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="reviewText" class="form-label">Review (optional)</label>
                            <textarea class="form-control" id="reviewText" name="review" rows="3" placeholder="Share your experience..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Submit Rating</button>
                    </div>
                </form>
            </div>
        </div>
    </div>


    <!-- ★★★ RIDE CHAT MODAL ★★★ -->
    <div class="modal fade" id="rideChatModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-chat"></i> 
                        <span id="chat-title">Chat for Ride</span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="chat-container" style="height: 400px;">
                        <!-- Chat Messages -->
                        <div id="chat-messages" class="chat-messages p-3" style="height: 320px; overflow-y: auto;"></div>
                        
                        <!-- Chat Input -->
                        <div class="chat-input p-3 border-top">
                            <div class="input-group">
                                <input type="text" id="chat-input" class="form-control" placeholder="Type your message...">
                                <button id="chat-send" class="btn btn-primary">
                                    <i class="bi bi-send"></i> Send
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>



    <!-- Add this line -->
    <script src="/js/dashboard.js"></script>
    <script src="/js/search.js"></script>
    <script src="/js/delete-ride.js"></script>
    <!-- Add this with your other scripts -->
<script src="/js/cancel-booking.js"></script>
<script src="/js/ratings.js"></script>
<!-- Add this with your other scripts -->
<script src="/js/ai-price-display.js"></script>



<!-- ★★★ SOCKET.IO & CHAT SCRIPT ★★★ -->
    <script src="/socket.io/socket.io.js"></script>
    <!-- In both dashboard.ejs and my-bookings.ejs -->
    <script src="/js/chat.js"></script>
    <script>
        // Debug: Check if everything is loaded
        console.log('=== DEBUG CHECK ===');
        console.log('DriverTracking:', typeof DriverTracking);
        console.log('driverTracking instance:', typeof driverTracking);
        console.log('Socket.io:', typeof io);
        console.log('Bootstrap:', typeof bootstrap);
        console.log('=== END DEBUG ===');
            
        // Test if button click works
        document.addEventListener('DOMContentLoaded', function() {
            const buttons = document.querySelectorAll('.start-tracking-btn');
            console.log('Found tracking buttons:', buttons.length);
            
            buttons.forEach(btn => {
                btn.addEventListener('click', function() {
                    console.log('📍 Tracking button clicked!');
                    console.log('Ride ID:', this.getAttribute('data-ride-id'));
                });
            });
        });
        </script>
        <!-- Add these before closing body tag -->
        <script src="/js/driver-tracking.js"></script>
        <script src="/js/rider-tracking.js"></script>
</body>
</html>