<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Bookings - RouteMate</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body data-user-id="<%= user.id %>">
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">
                <i class="bi bi-geo-alt-fill me-2"></i>RouteMate
            </a>
            <div class="navbar-nav ms-auto">
                <span class="navbar-text me-3">
                    Welcome, <strong><%= user.name %></strong>!
                </span>
                <a href="/dashboard" class="btn btn-outline-light btn-sm me-2">
                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                </a>
                <a href="/auth/logout" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2><i class="bi bi-journal-check me-2"></i>My Bookings</h2>
                    <span class="badge bg-primary fs-6"><%= bookings.length %> booking(s)</span>
                </div>

                <% if (bookings.length === 0) { %>
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> You haven't booked any rides yet. 
                        <a href="/dashboard" class="alert-link">Find rides to book</a>.
                    </div>
                <% } else { %>
                    <div class="row">
                        <% bookings.forEach(function(booking) { %>
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card h-100 shadow-sm">
                                    <div class="card-header bg-success text-white">
                                        <strong>Booking #<%= booking.booking_id %></strong>
                                    </div>
                                    <div class="card-body">
                                        <h6 class="card-title"><%= booking.start_location %> to <%= booking.end_location %></h6>
                                        
                                        <% if (booking.pickup_instructions) { %>
                                            <div class="alert alert-info py-2 mb-3">
                                                <small>
                                                    <i class="bi bi-info-circle"></i> 
                                                    <strong>Pickup:</strong> <%= booking.pickup_instructions %>
                                                </small>
                                            </div>
                                        <% } %>
                                        
                                        <div class="mb-2">
                                            <i class="bi bi-person"></i> <strong>Driver:</strong> 
                                            <%= booking.driver_name %>
                                        </div>
                                        
                                        <div class="mb-2">
                                            <i class="bi bi-clock"></i> <strong>Ride Time:</strong> 
                                            <%= new Date(booking.ride_time).toLocaleString() %>
                                        </div>
                                        
                                        <div class="mb-2">
                                            <i class="bi bi-people"></i> <strong>Seats Booked:</strong> 
                                            <span class="badge bg-primary"><%= booking.seats_booked %></span>
                                        </div>
                                        
                                        <div class="mb-2">
                                            <i class="bi bi-calendar"></i> <strong>Booked On:</strong> 
                                            <%= new Date(booking.created_at).toLocaleDateString() %>
                                        </div>
                                        
                                        <div class="mb-2">
                                            <i class="bi bi-star"></i> <strong>Status:</strong> 
                                            <span class="badge bg-<%= booking.booking_status === 'confirmed' ? 'success' : 'warning' %>">
                                                    <%= booking.booking_status %>
                                            </span>
                                        </div>

                                        <!-- ★★★ ADD CHAT BUTTON FOR BOOKED RIDES ★★★ -->
                                        <% if (booking.booking_status === 'confirmed') { %>
                                            <div class="d-grid gap-2 mt-3">
                                                <button class="btn btn-outline-primary btn-sm" 
                                                        onclick="openRideChat('<%= booking.ride_id %>', '<%= booking.driver_id %>', '<%= booking.driver_name %>')">
                                                    <i class="bi bi-chat"></i> Chat with Driver
                                                </button>
                                                <!-- ★★★ ADD TRACK RIDE BUTTON ★★★ -->
                                                <button class="btn btn-info btn-sm track-ride-btn" 
                                                        data-ride-id="<%= booking.ride_id %>"
                                                        data-driver-name="<%= booking.driver_name %>">
                                                    <i class="bi bi-map"></i> Track Driver
                                                </button>
                                            </div>
                                        <% } %>
                                        <!-- ★★★ END CHAT BUTTON ★★★ -->

        


                        <!-- RATE BUTTON for completed rides -->
<% const isFutureRide = new Date(booking.ride_time) > new Date(); %>
<% if (!isFutureRide && booking.booking_status === 'confirmed') { %>
    <div class="d-grid mt-2">
        <button class="btn btn-outline-warning btn-sm" 
                onclick='openRatingModal("<%=booking.ride_id%>")'>
            <i class="bi bi-star"></i> Rate This Ride
        </button>
    </div>
<% } else if (!isFutureRide) { %>
    <div class="text-center">
        <small class="text-muted">Ride completed</small>
    </div>
<% } %>

                                        <!-- CANCEL BUTTON for future rides -->
                                        <% if (booking.booking_status === 'confirmed' && isFutureRide) { %>
                                            <div class="d-grid mt-2">
                                                <button class="btn btn-outline-danger btn-sm cancel-booking-btn" 
                                                        data-booking-id="<%= booking.booking_id %>"
                                                        data-ride-route="<%= booking.start_location %> to <%= booking.end_location %>">
                                                    <i class="bi bi-x-circle"></i> Cancel Booking
                                                </button>
                                            </div>

                                        <% } else if (!isFutureRide) { %>
                                            <div class="text-center">
                                                <small class="text-muted">Ride completed</small>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/cancel-booking.js"></script>

     <!-- Rating Modal -->
    <div class="modal fade" id="ratingModal" tabindex="-1" aria-labelledby="ratingModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="ratingModalLabel">Rate Your Ride</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="ratingForm">
                    <div class="modal-body">
                        <input type="hidden" id="ratingRideId" name="ride_id">
                        
                        <div class="mb-3">
                            <label class="form-label">How was your ride?</label>
                            <div class="rating-stars mb-3">
                                <% for (let i = 1; i <= 5; i++) { %>
                                    <i class="bi bi-star rating-star" data-rating="<%= i %>" style="cursor: pointer; font-size: 2rem; color: #ddd;"></i>
                                <% } %>
                            </div>
                            <input type="hidden" id="ratingValue" name="rating" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="reviewText" class="form-label">Review (optional)</label>
                            <textarea class="form-control" id="reviewText" name="review" rows="3" placeholder="Share your experience..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Submit Rating</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ★★★ RIDE CHAT MODAL ★★★ -->
    <div class="modal fade" id="rideChatModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-chat"></i> 
                        <span id="chat-title">Chat for Ride</span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="chat-container" style="height: 400px;">
                        <!-- Chat Messages -->
                        <div id="chat-messages" class="chat-messages p-3" style="height: 320px; overflow-y: auto;"></div>
                        
                        <!-- Chat Input -->
                        <div class="chat-input p-3 border-top">
                            <div class="input-group">
                                <input type="text" id="chat-input" class="form-control" placeholder="Type your message...">
                                <button id="chat-send" class="btn btn-primary">
                                    <i class="bi bi-send"></i> Send
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <script src="/js/ratings.js"></script>
    <!-- In both dashboard.ejs and my-bookings.ejs -->
     <script src="/socket.io/socket.io.js"></script>
    <script src="/js/chat.js"></script>
    <!-- Add these before closing body tag -->
    <script src="/js/driver-tracking.js"></script>
    <script src="/js/rider-tracking.js"></script>

</body>
</html>