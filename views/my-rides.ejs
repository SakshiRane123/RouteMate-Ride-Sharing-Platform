<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Rides - RouteMate</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">
                <i class="bi bi-geo-alt-fill me-2"></i>RouteMate
            </a>
            <div class="navbar-nav ms-auto">
                <span class="navbar-text me-3">
                    Welcome, <strong><%= user.name %></strong>!
                </span>
                <a href="/dashboard" class="btn btn-outline-light btn-sm me-2">
                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                </a>
                <a href="/auth/logout" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2><i class="bi bi-car-front me-2"></i>My Rides</h2>
                    <span class="badge bg-primary fs-6"><%= rides.length %> ride(s)</span>
                </div>

                <% if (rides.length === 0) { %>
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> You haven't offered any rides yet. 
                        <a href="/dashboard" class="alert-link">Create your first ride</a>.
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Route</th>
                                    <th>Date & Time</th>
                                    <th>Seats</th>
                                    <th>Bookings</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% rides.forEach(function(ride) { %>
                                    <tr>
                                        <td>
                                            <strong><%= ride.start_location %></strong> 
                                            <i class="bi bi-arrow-right"></i> 
                                            <strong><%= ride.end_location %></strong>
                                        </td>
                                        <td><%= new Date(ride.ride_time).toLocaleString() %></td>
                                        <td>
                                            <span class="badge bg-<%= ride.seats_available > 0 ? 'success' : 'danger' %>">
                                                <%= ride.seats_available %> / <%= ride.seats_available + ride.total_bookings %>
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge bg-info"><%= ride.total_bookings || 0 %></span>
                                        </td>
                                        <td>
                                            <% const isPast = new Date(ride.ride_time) < new Date(); %>
                                            <span class="badge bg-<%= isPast ? 'secondary' : 'primary' %>">
                                                <%= isPast ? 'Completed' : 'Upcoming' %>
                                            </span>
                                        </td>
                                        <td>
                                            <a href="/ride/<%= ride.id %>/bookings" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-people"></i> View Bookings
                                            </a>
                                            <!-- NEW: Delete Button -->
                                            <button class="btn btn-sm btn-outline-danger delete-ride-btn" 
                                                data-ride-id="<%= ride.id %>"
                                                data-ride-route="<%= ride.start_location %> to <%= ride.end_location %>">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/delete-ride.js"></script>
</body>
</html>