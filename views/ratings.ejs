<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ratings & Reviews - RouteMate</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">RouteMate</a>
            <div class="navbar-nav ms-auto">
                <a href="/dashboard" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <h2><i class="bi bi-star-fill text-warning"></i> Ratings for <%= driverName %></h2>
                
                <div class="row mt-4">
                    <div class="col-md-4">
                        <div class="card text-center">
                            <div class="card-body">
                                <h1 class="display-1 text-warning"><%= averageRating ? averageRating.toFixed(1) : '0.0' %></h1>
                                <h5>Average Rating</h5>
                                <div class="rating-stars mb-2">
                                    <% for (let i = 1; i <= 5; i++) { %>
                                        <i class="bi bi-star-fill <%= i <= Math.round(averageRating) ? 'text-warning' : 'text-secondary' %>"></i>
                                    <% } %>
                                </div>
                                <p class="text-muted"><%= totalRatings %> reviews</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-8">
                        <% if (ratings.length === 0) { %>
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle"></i> No reviews yet for this driver.
                            </div>
                        <% } else { %>
                            <% ratings.forEach(function(review) { %>
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h5 class="card-title"><%= review.rider_name %></h5>
                                                <p class="text-muted">
                                                    <%= new Date(review.created_at).toLocaleDateString() %>
                                                </p>
                                            </div>
                                            <div class="rating-stars">
                                                <% for (let i = 1; i <= 5; i++) { %>
                                                    <i class="bi bi-star-fill <%= i <= review.rating ? 'text-warning' : 'text-secondary' %>"></i>
                                                <% } %>
                                            </div>
                                        </div>
                                        <% if (review.review) { %>
                                            <p class="card-text mt-2">"<%= review.review %>"</p>
                                        <% } %>
                                    </div>
                                </div>
                            <% }); %>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>