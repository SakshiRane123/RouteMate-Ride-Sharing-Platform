<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ride Bookings - RouteMate</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">
                <i class="bi bi-geo-alt-fill me-2"></i>RouteMate
            </a>
            <div class="navbar-nav ms-auto">
                <span class="navbar-text me-3">
                    Welcome, <strong><%= user.name %></strong>!
                </span>
                <a href="/my-rides" class="btn btn-outline-light btn-sm me-2">
                    <i class="bi bi-arrow-left me-1"></i>Back to My Rides
                </a>
                <a href="/auth/logout" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2><i class="bi bi-people me-2"></i>Ride Bookings</h2>
                        <p class="text-muted mb-0">
                            <%= ride.start_location %> to <%= ride.end_location %> • 
                            <%= new Date(ride.ride_time).toLocaleString() %>
                        </p>
                    </div>
                    <span class="badge bg-primary fs-6"><%= bookings.length %> booking(s)</span>
                </div>

                <% if (bookings.length === 0) { %>
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> No bookings for this ride yet.
                    </div>
                <% } else { %>
                    <div class="card shadow-sm">
                        <div class="card-header bg-dark text-white">
                            <h5 class="card-title mb-0">Passenger List</h5>
                        </div>
                        <div class="card-body">
                            <div class="alert alert-primary mb-3">
                                <h6>Ride Details:</h6>
                                <p class="mb-1"><strong>Route:</strong> <%= ride.start_location %> to <%= ride.end_location %></p>
                                <p class="mb-1"><strong>Time:</strong> <%= new Date(ride.ride_time).toLocaleString() %></p>
                                 <% if (ride.pickup_instructions) { %>
                                <p class="mb-0"><strong>Pickup Instructions:</strong> <%= ride.pickup_instructions %></p>
                                <% } %>
                                <!-- ADD THIS IN THE RIDE DETAILS SECTION -->
                                <% if (ride.description) { %>
                                  <div class="alert alert-info mt-2">
                                    <i class="bi bi-chat-left-quote"></i>
                                    <strong>Ride Description:</strong>
                                    <p class="mb-0">"<%= ride.description %>"</p>
                                  </div>
                                <% } %>

                            </div>
                            <div class="table-responsive">
                                <table class="table table-striped">
                                    <thead>
                                        <tr>
                                            <th>Passenger</th>
                                            <th>Contact</th>
                                            <th>Seats</th>
                                            <th>Booked On</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% bookings.forEach(function(booking) { %>
                                            <tr>
                                                <td>
                                                    <strong><%= booking.rider_name %></strong>
                                                </td>
                                                <td>
                                                    <small class="text-muted"><%= booking.rider_email %></small>
                                                </td>
                                                <td>
                                                    <span class="badge bg-primary"><%= booking.seats_booked %></span>
                                                </td>
                                                <td>
                                                    <%= new Date(booking.created_at).toLocaleDateString() %>
                                                </td>
                                                <td>
                                                    <span class="badge bg-<%= booking.status === 'confirmed' ? 'success' : 'warning' %>">
                                                        <%= booking.status %>
                                                    </span>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>